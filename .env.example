# ─────────────────────────────────────────────────────
# Kisan.AI  –  Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=your-very-secret-key-change-this
DEBUG=True

# Google Gemini API  (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio SMS/WhatsApp  (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# OpenWeatherMap  (optional, https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Blockchain  (leave blank to run in mock/demo mode)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:7545
CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
